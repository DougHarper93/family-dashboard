# Family Dashboard - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# -------------------------------------------------------
# PostgreSQL Database
# -------------------------------------------------------
DB_NAME=family_dashboard
DB_USER=family_user
DB_PASS=change_me_strong_password

# -------------------------------------------------------
# ntfy.sh — push notifications for shopping list
# Use the free cloud: https://ntfy.sh/your-topic-name
# Pick something non-obvious, e.g. https://ntfy.sh/smithfamily-shopping-a7x2
# -------------------------------------------------------
NTFY_TOPIC=https://ntfy.sh/your-topic-name-here
